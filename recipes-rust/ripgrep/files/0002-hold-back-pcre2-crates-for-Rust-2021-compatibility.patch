From 3df8f36ed59e100e225ded53d97f08b6766f39c9 Mon Sep 17 00:00:00 2001
From: Allen Wild <allenwild93@gmail.com>
Date: Sun, 2 Nov 2025 16:14:19 -0500
Subject: [PATCH 2/2] hold back pcre2 crates for Rust 2021 compatibility

---
 Cargo.lock              | 9 +++++----
 crates/pcre2/Cargo.toml | 3 ++-
 2 files changed, 7 insertions(+), 5 deletions(-)

diff --git a/Cargo.lock b/Cargo.lock
index 51c5f1f..814fd8f 100644
--- a/Cargo.lock
+++ b/Cargo.lock
@@ -198,6 +198,7 @@ dependencies = [
  "grep-matcher",
  "log",
  "pcre2",
+ "pcre2-sys",
 ]
 
 [[package]]
@@ -308,9 +309,9 @@ dependencies = [
 
 [[package]]
 name = "pcre2"
-version = "0.2.10"
+version = "0.2.9"
 source = "registry+https://github.com/rust-lang/crates.io-index"
-checksum = "808e8d61d1a3a1d46fe71b3caa1b3785833e22192bd19f121ef8ddee4cbf9eed"
+checksum = "3be55c43ac18044541d58d897e8f4c55157218428953ebd39d86df3ba0286b2b"
 dependencies = [
  "libc",
  "log",
@@ -319,9 +320,9 @@ dependencies = [
 
 [[package]]
 name = "pcre2-sys"
-version = "0.2.10"
+version = "0.2.9"
 source = "registry+https://github.com/rust-lang/crates.io-index"
-checksum = "18b9073c1a2549bd409bf4a32c94d903bb1a09bf845bc306ae148897fa0760a4"
+checksum = "550f5d18fb1b90c20b87e161852c10cde77858c3900c5059b5ad2a1449f11d8a"
 dependencies = [
  "cc",
  "libc",
diff --git a/crates/pcre2/Cargo.toml b/crates/pcre2/Cargo.toml
index a5f6852..27606b0 100644
--- a/crates/pcre2/Cargo.toml
+++ b/crates/pcre2/Cargo.toml
@@ -16,4 +16,5 @@ edition = "2018"
 [dependencies]
 grep-matcher = { version = "0.1.7", path = "../matcher" }
 log = "0.4.20"
-pcre2 = "0.2.6"
+pcre2 = "=0.2.9"
+pcre2-sys = "=0.2.9"
-- 
2.51.2

